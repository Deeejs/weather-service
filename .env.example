# Copy to .env and adjust as needed. All values are optional — config.ts
# provides sensible defaults.

# Port the HTTP server listens on.
PORT=3000

# Base URL for the National Weather Service API.
NWS_BASE_URL=https://api.weather.gov

# Sent on every NWS request. NWS asks for a real contact (email or URL).
USER_AGENT=ts-weather-api (contact@example.com)

# Per-request timeout for NWS calls, in milliseconds.
NWS_TIMEOUT_MS=5000
